+      ],
+      "code": "def {{nama_fungsi}}(limit):\n    \"\"\"Yield primes up to limit.\"\"\"\n    if limit < 2:\n        return\n    sieve = bytearray(b'\\x01') * (limit + 1)\n    sieve[0:2] = b'\\x00\\x00'\n    import math\n    for p in range(2, int(math.isqrt(limit)) + 1):\n        if sieve[p]:\n            step = p\n            start = p*p\n            sieve[start:limit+1:step] = b'\\x00' * ((limit - start)//step + 1)\n    for i in range(2, limit+1):\n        if sieve[i]:\n            yield i\n",
+      "sample_values": {
+        "nama_fungsi": "prime_generator"
