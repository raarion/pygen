+          "default": 2
+        }
+      ],
+      "code": "def {{nama_fungsi}}(a, b, n={{n}}):\n    \"\"\"Dice coefficient dengan n-grams.\"\"\"\n    def ngrams(s, n):\n        return set(s[i:i+n] for i in range(len(s)-n+1))\n    if not a and not b:\n        return 1.0\n    A = ngrams(a.lower(), n)\n    B = ngrams(b.lower(), n)\n    if not A and not B:\n        return 1.0\n    inter = len(A & B)\n    return 2 * inter / (len(A) + len(B)) if (len(A) + len(B)) else 0.0\n",
