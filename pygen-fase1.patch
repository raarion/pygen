+        {
+          "name": "nama_fungsi",
+          "label": "Nama fungsi",
+          "type": "identifier",
+          "default": "knapsack_01"
+        }
+      ],
+      "code": "def {{nama_fungsi}}(weights, values, capacity):\n    \"\"\"0/1 Knapsack. Return max value.\"\"\"\n    n = len(weights)\n    dp = [0] * (capacity + 1)\n    for i in range(n):\n        w = weights[i]\n        v = values[i]\n        for c in range(capacity, w-1, -1):\n            dp[c] = max(dp[c], dp[c-w] + v)\n    return dp[capacity]\n",
+      "sample_values": {
