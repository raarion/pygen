+      "code": "class {{nama_class}}:\n    \"\"\"Priority queue berbasis heapq.\"\"\"\n    def __init__(self):\n        import heapq\n        self._heap = []\n        self._counter = 0\n\n    def push(self, item, priority=0):\n        import heapq\n        heapq.heappush(self._heap, (priority, self._counter, item))\n        self._counter += 1\n\n    def pop(self):\n        import heapq\n        if not self._heap:\n            raise IndexError(\"pop from empty queue\")\n        return heapq.heappop(self._heap)[2]\n\n    def peek(self):\n        if not self._heap:\n            return None\n        return self._heap[0][2]\n\n    def __len__(self):\n        return len(self._heap)\n\n    def __bool__(self):\n        return bool(self._heap)\n",
