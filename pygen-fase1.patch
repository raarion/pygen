+      "code": "class {{nama_class}}:\n    \"\"\"Ring buffer ukuran tetap.\"\"\"\n    def __init__(self, capacity={{capacity}}):\n        self.capacity = capacity\n        self._buf = [None] * capacity\n        self._start = 0\n        self._size = 0\n\n    def append(self, item):\n        idx = (self._start + self._size) % self.capacity\n        if self._size == self.capacity:\n            self._start = (self._start + 1) % self.capacity\n            idx = (self._start + self._size - 1) % self.capacity\n        else:\n            self._size += 1\n        self._buf[idx] = item\n\n    def get_all(self):\n        return [self._buf[(self._start + i) % self.capacity] for i in range(self._size)]\n\n    def __len__(self):\n        return self._size\n\n    def clear(self):\n        self._start = 0\n        self._size = 0\n",
