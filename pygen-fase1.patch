+      "code": "def {{nama_fungsi}}(s):\n    \"\"\"Parse date dari berbagai format.\"\"\"\n    import datetime\n    formats = [\n        '%Y-%m-%d', '%d/%m/%Y', '%m/%d/%Y', '%d-%m-%Y',\n        '%Y/%m/%d', '%d %b %Y', '%d %B %Y', '%b %d, %Y'\n    ]\n    s = s.strip()\n    for fmt in formats:\n        try:\n            return datetime.datetime.strptime(s, fmt).date()\n        except ValueError:\n            continue\n    raise ValueError(f'Tidak bisa parse tanggal: {s}')\n",
