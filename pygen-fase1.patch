+      ],
+      "code": "def {{nama_fungsi}}(data, method='minmax'):\n    \"\"\"method: 'minmax' atau 'zscore'.\"\"\"\n    data = list(data)\n    if not data:\n        return []\n    if method == 'zscore':\n        import statistics\n        mean = statistics.mean(data)\n        stdev = statistics.stdev(data) if len(data) > 1 else 1\n        return [(x - mean) / stdev if stdev else 0 for x in data]\n    else:\n        mn, mx = min(data), max(data)\n        rng = mx - mn or 1\n        return [(x - mn) / rng for x in data]\n",
