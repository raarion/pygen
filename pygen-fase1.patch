+      ],
+      "code": "def {{nama_fungsi}}(data, p):\n    \"\"\"Percentile 0-100.\"\"\"\n    data = sorted(data)\n    if not data:\n        return None\n    k = (len(data)-1) * p / 100.0\n    f = int(k)\n    c = min(f+1, len(data)-1)\n    if f == c:\n        return data[f]\n    d0 = data[f] * (c - k)\n    d1 = data[c] * (k - f)\n    return d0 + d1\n",
+      "sample_values": {
+        "nama_fungsi": "percentile"
+      }
+    },
