+        }
+      ],
+      "code": "def {{nama_fungsi}}(graph):\n    \"\"\"graph: dict node -> list neighbors. Return topo order list.\"\"\"\n    from collections import deque, defaultdict\n    indeg = defaultdict(int)\n    nodes = set(graph.keys())\n    for u in graph:\n        for v in graph[u]:\n            indeg[v] += 1\n            nodes.add(v)\n    q = deque([n for n in nodes if indeg[n] == 0])\n    order = []\n    while q:\n        u = q.popleft()\n        order.append(u)\n        for v in graph.get(u, []):\n            indeg[v] -= 1\n            if indeg[v] == 0:\n                q.append(v)\n    if len(order) != len(nodes):\n        raise ValueError(\"Graph contains cycle\")\n    return order\n",
