+      "code": "def {{nama_fungsi}}(x, y):\n    \"\"\"Return {'slope': m, 'intercept': b, 'r2': r2}.\"\"\"\n    n = len(x)\n    if n == 0 or n != len(y):\n        raise ValueError('x and y must match')\n    sx = sum(x); sy = sum(y)\n    sxy = sum(a*b for a, b in zip(x, y))\n    sxx = sum(a*a for a in x)\n    denom = n * sxx - sx * sx\n    if denom == 0:\n        return {'slope': 0, 'intercept': sy/n if n else 0, 'r2': 0}\n    m = (n * sxy - sx * sy) / denom\n    b = (sy - m * sx) / n\n    y_mean = sy / n\n    ss_tot = sum((yi - y_mean)**2 for yi in y)\n    ss_res = sum((yi - (m*xi + b))**2 for xi, yi in zip(x, y))\n    r2 = 1 - ss_res / ss_tot if ss_tot else 0\n    return {'slope': m, 'intercept': b, 'r2': r2}\n",
+      "sample_values": {
+        "nama_fungsi": "linear_regression"
+      }
+    },
