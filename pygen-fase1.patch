+      "code": "def {{nama_fungsi}}(s1, s2):\n    \"\"\"Hitung Levenshtein distance.\"\"\"\n    if len(s1) < len(s2):\n        return {{nama_fungsi}}(s2, s1)\n    previous = list(range(len(s2) + 1))\n    for i, c1 in enumerate(s1, 1):\n        current = [i]\n        for j, c2 in enumerate(s2, 1):\n            ins = previous[j] + 1\n            delete = current[j-1] + 1\n            sub = previous[j-1] + (c1 != c2)\n            current.append(min(ins, delete, sub))\n        previous = current\n    return previous[-1]\n",
