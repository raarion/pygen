+      "code": "def {{nama_fungsi}}(start, end):\n    \"\"\"Hitung business days. start/end: date.\"\"\"\n    import datetime\n    if start > end:\n        start, end = end, start\n    days = 0\n    cur = start\n    one_day = datetime.timedelta(days=1)\n    while cur <= end:\n        if cur.weekday() < 5:\n            days += 1\n        cur += one_day\n    return days\n",
