+      "code": "def {{nama_fungsi}}(text):\n    \"\"\"Convert text ke slug.\"\"\"\n    import re\n    import unicodedata\n    text = unicodedata.normalize('NFKD', text)\n    text = text.encode('ascii', 'ignore').decode('ascii')\n    text = re.sub(r'[^\\w\\s-]', '', text.lower())\n    text = re.sub(r'[-\\s]+', '-', text).strip('-_')\n    return text\n",
