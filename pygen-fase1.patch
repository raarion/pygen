+          "default": "combinatorics"
+        }
+      ],
+      "code": "def {{nama_fungsi}}_nCk(n, k):\n    \"\"\"n choose k.\"\"\"\n    import math\n    if hasattr(math, 'comb'):\n        return math.comb(n, k)\n    k = min(k, n-k)\n    result = 1\n    for i in range(1, k+1):\n        result = result * (n - k + i) // i\n    return result\n\ndef {{nama_fungsi}}_nPk(n, k):\n    \"\"\"n permute k.\"\"\"\n    import math\n    if hasattr(math, 'perm'):\n        return math.perm(n, k)\n    result = 1\n    for i in range(n, n-k, -1):\n        result *= i\n    return result\n",
+      "sample_values": {
+        "nama_fungsi": "combinatorics"
