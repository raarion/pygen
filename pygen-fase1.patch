+      "code": "def {{nama_fungsi}}(data, window={{window}}, ema=False):\n    \"\"\"Return moving average list.\"\"\"\n    data = list(data)\n    if not data or window <= 0:\n        return []\n    if ema:\n        alpha = 2 / (window + 1)\n        result = []\n        ema_val = data[0]\n        for x in data:\n            ema_val = alpha * x + (1 - alpha) * ema_val\n            result.append(ema_val)\n        return result\n    else:\n        result = []\n        for i in range(len(data) - window + 1):\n            result.append(sum(data[i:i+window]) / window)\n        return result\n",
