+      "code": "def {{nama_fungsi}}(text, max_len={{max_len}}):\n    \"\"\"Truncate tanpa potong kata.\"\"\"\n    if len(text) <= max_len:\n        return text\n    truncated = text[:max_len].rsplit(' ', 1)[0]\n    return truncated + '...'\n",
