+    },
+    {
+      "id": "linear_regression",
+      "title": "Simple linear regression",
+      "description": "y = mx + b dari (x,y) pairs",
+      "imports": [],
+      "requires": {},
+      "fields": [
+        {
+          "name": "nama_fungsi",
+          "label": "Nama fungsi",
+          "type": "identifier",
+          "default": "linear_regression"
