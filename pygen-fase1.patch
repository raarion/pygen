+      "code": "def {{nama_fungsi}}(seconds):\n    \"\"\"Format detik ke human readable ID.\"\"\"\n    seconds = int(seconds)\n    parts = []\n    h, rem = divmod(seconds, 3600)\n    m, s = divmod(rem, 60)\n    if h: parts.append(f'{h} jam')\n    if m: parts.append(f'{m} menit')\n    if s or not parts: parts.append(f'{s} detik')\n    return ' '.join(parts)\n",
