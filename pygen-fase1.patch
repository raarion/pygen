+      "code": "def {{nama_fungsi}}(data):\n    \"\"\"Return dict mean, median, mode, stdev, min, max.\"\"\"\n    import statistics\n    data = list(data)\n    if not data:\n        return {}\n    result = {}\n    result['count'] = len(data)\n    result['mean'] = statistics.mean(data)\n    result['median'] = statistics.median(data)\n    try:\n        result['mode'] = statistics.mode(data)\n    except statistics.StatisticsError:\n        result['mode'] = None\n    result['stdev'] = statistics.stdev(data) if len(data) > 1 else 0.0\n    result['min'] = min(data)\n    result['max'] = max(data)\n    return result\n",
