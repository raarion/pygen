+      "code": "def {{nama_fungsi}}(path, n={{n_lines}}, encoding='utf-8'):\n    \"\"\"Return n baris terakhir.\"\"\"\n    with open(path, 'rb') as f:\n        f.seek(0, 2)\n        size = f.tell()\n        block = 1024\n        data = b''\n        while len(data.splitlines()) <= n and f.tell() > 0:\n            step = min(block, f.tell())\n            f.seek(-step, 1)\n            data = f.read(step) + data\n            f.seek(-step, 1)\n            if f.tell() == 0:\n                break\n        lines = data.decode(encoding, errors='replace').splitlines()\n        return lines[-n:]\n",
