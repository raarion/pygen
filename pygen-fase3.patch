+      "code": "class {{nama_class}}:\n    \"\"\"CORS header generator.\n    Returns dict of headers to add to HTTP response.\n    \"\"\"\n    def __init__(self, allowed_origins=None, allowed_methods=None, allowed_headers=None, max_age=86400):\n        self.allowed_origins = allowed_origins or ['{{default_origin}}']\n        self.allowed_methods = allowed_methods or ['GET', 'POST', 'PUT', 'DELETE', 'OPTIONS']\n        self.allowed_headers = allowed_headers or ['Content-Type', 'Authorization']\n        self.max_age = max_age\n\n    def _origin_allowed(self, origin):\n        if '*' in self.allowed_origins:\n            return True\n        return origin in self.allowed_origins\n\n    def get_headers(self, request_origin=None):\n        \"\"\"Generate CORS headers based on request origin.\"\"\"\n        headers = {}\n        if request_origin and self._origin_allowed(request_origin):\n            headers['Access-Control-Allow-Origin'] = request_origin\n            headers['Vary'] = 'Origin'\n        elif '*' in self.allowed_origins:\n            headers['Access-Control-Allow-Origin'] = '*'\n        else:\n            return {}\n        headers['Access-Control-Allow-Methods'] = ', '.join(self.allowed_methods)\n        headers['Access-Control-Allow-Headers'] = ', '.join(self.allowed_headers)\n        headers['Access-Control-Max-Age'] = str(self.max_age)\n        return headers\n\n    def get_preflight_headers(self, request_origin=None):\n        \"\"\"Headers for OPTIONS preflight response.\"\"\"\n        return self.get_headers(request_origin)\n",
