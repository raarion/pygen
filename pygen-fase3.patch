+      ],
+      "code": "class {{nama_exception}}(Exception):\n    \"\"\"Raised when request validation fails.\"\"\"\n    def __init__(self, errors):\n        self.errors = errors\n        super().__init__(str(errors))\n\n\nclass {{nama_class}}:\n    \"\"\"Validate request data against a simple schema.\n    Schema format: {'field_name': {'type': str, 'required': True, 'min': 0, 'max': 100}}\n    \"\"\"\n    TYPE_MAP = {'str': str, 'int': int, 'float': float, 'bool': bool, 'list': list, 'dict': dict}\n\n    def __init__(self, schema):\n        self.schema = schema\n\n    def validate(self, data):\n        \"\"\"Validate data against schema. Raise ValidationError if invalid.\n        Returns cleaned data dict.\n        \"\"\"\n        errors = []\n        cleaned = {}\n        for field, rules in self.schema.items():\n            required = rules.get('required', False)\n            expected_type = rules.get('type')\n            if field not in data:\n                if required:\n                    errors.append({'field': field, 'error': 'required'})\n                continue\n            value = data[field]\n            if expected_type:\n                type_cls = self.TYPE_MAP.get(expected_type, expected_type)\n                if not isinstance(value, type_cls):\n                    errors.append({'field': field, 'error': 'type', 'expected': expected_type, 'got': type(value).__name__})\n                    continue\n            if 'min' in rules and isinstance(value, (int, float)) and value < rules['min']:\n                errors.append({'field': field, 'error': 'min', 'min': rules['min']})\n            if 'max' in rules and isinstance(value, (int, float)) and value > rules['max']:\n                errors.append({'field': field, 'error': 'max', 'max': rules['max']})\n            if 'min_length' in rules and isinstance(value, str) and len(value) < rules['min_length']:\n                errors.append({'field': field, 'error': 'min_length', 'min': rules['min_length']})\n            if 'max_length' in rules and isinstance(value, str) and len(value) > rules['max_length']:\n                errors.append({'field': field, 'error': 'max_length', 'max': rules['max_length']})\n            if 'choices' in rules and value not in rules['choices']:\n                errors.append({'field': field, 'error': 'choices', 'allowed': rules['choices']})\n            cleaned[field] = value\n        if errors:\n            raise {{nama_exception}}(errors)\n        return cleaned\n",
