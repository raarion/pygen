+      "code": "class {{nama_class}}:\n    \"\"\"Thread-safe in-memory response cache with TTL.\"\"\"\n    def __init__(self, default_ttl={{default_ttl}}):\n        self.default_ttl = default_ttl\n        self._cache = {}\n        self._lock = threading.Lock()\n\n    def _make_key(self, method, url, params=None):\n        key = method.upper() + ':' + url\n        if params:\n            import urllib.parse\n            key += '?' + urllib.parse.urlencode(sorted(params.items()))\n        return key\n\n    def get(self, method, url, params=None):\n        key = self._make_key(method, url, params)\n        with self._lock:\n            entry = self._cache.get(key)\n            if entry and time.time() < entry['expires_at']:\n                return entry['data']\n            if entry:\n                del self._cache[key]\n        return None\n\n    def put(self, method, url, data, params=None, ttl=None):\n        key = self._make_key(method, url, params)\n        ttl = ttl if ttl is not None else self.default_ttl\n        with self._lock:\n            self._cache[key] = {\n                'data': data,\n                'expires_at': time.time() + ttl,\n            }\n\n    def clear(self):\n        with self._lock:\n            self._cache.clear()\n\n    def cleanup(self):\n        now = time.time()\n        with self._lock:\n            expired = [k for k, v in self._cache.items() if now >= v['expires_at']]\n            for k in expired:\n                del self._cache[k]\n",
