+      "code": "class {{nama_class}}:\n    \"\"\"Generic API paginator supporting offset and cursor modes.\"\"\"\n    def __init__(self, fetch_func, page_size={{page_size}}):\n        self.fetch_func = fetch_func\n        self.page_size = page_size\n\n    def paginate_offset(self, url, items_key='results', next_key='next', page_param='page', size_param='per_page'):\n        \"\"\"Offset-based pagination. fetch_func(url) must return dict.\"\"\"\n        page = 1\n        while True:\n            sep = '&' if '?' in url else '?'\n            paged_url = url + sep + page_param + '=' + str(page) + '&' + size_param + '=' + str(self.page_size)\n            data = self.fetch_func(paged_url)\n            items = data.get(items_key, [])\n            if not items:\n                break\n            yield from items\n            if not data.get(next_key):\n                break\n            page += 1\n\n    def paginate_cursor(self, url, items_key='results', cursor_key='next_cursor', cursor_param='cursor'):\n        \"\"\"Cursor-based pagination.\"\"\"\n        cursor = None\n        while True:\n            sep = '&' if '?' in url else '?'\n            if cursor:\n                paged_url = url + sep + cursor_param + '=' + str(cursor)\n            else:\n                paged_url = url\n            data = self.fetch_func(paged_url)\n            items = data.get(items_key, [])\n            if not items:\n                break\n            yield from items\n            cursor = data.get(cursor_key)\n            if not cursor:\n                break\n",
