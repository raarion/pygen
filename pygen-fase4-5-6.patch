new file mode 100644
index 0000000..0c054fc
--- /dev/null
+++ b/pygen/templates/debug/debug.json
@@ -0,0 +1,102 @@
+{
+  "category": "debug",
+  "label": "Debug",
+  "templates": [
+    {
+      "id": "traceback_formatter",
+      "title": "Pretty Traceback Formatter",
+      "description": "Format exception traceback dengan konteks kode di sekitarnya. Stdlib only.",
+      "imports": ["traceback", "linecache", "os"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "format_traceback"},
+        {"name": "context_lines", "label": "Context lines around error", "type": "int", "default": 3}
+      ],
+      "code": "def {{nama_fungsi}}(exc=None, context_lines={{context_lines}}):\n    \"\"\"Format exception with source code context around error lines.\n    If exc is None, uses sys.exc_info() current exception.\n    Returns formatted string.\n    \"\"\"\n    import sys\n    if exc is None:\n        exc_info = sys.exc_info()\n        if exc_info[0] is None:\n            return '(no active exception)'\n        tb_lines = traceback.format_exception(*exc_info)\n    elif isinstance(exc, BaseException):\n        tb_lines = traceback.format_exception(type(exc), exc, exc.__traceback__)\n    else:\n        return str(exc)\n    output = []\n    for line in tb_lines:\n        output.append(line.rstrip())\n        for part in line.split('\\n'):\n            stripped = part.strip()\n            if stripped.startswith('File \"') and ', line ' in stripped:\n                try:\n                    parts = stripped.split('\", line ')\n                    filepath = parts[0].replace('File \"', '')\n                    lineno = int(parts[1].split(',')[0])\n                    for offset in range(-context_lines, context_lines + 1):\n                        ln = lineno + offset\n                        if ln < 1:\n                            continue\n                        src = linecache.getline(filepath, ln).rstrip()\n                        if src:\n                            marker = ' >>>' if offset == 0 else '    '\n                            output.append(marker + str(ln).rjust(4) + ' | ' + src)\n                except (ValueError, IndexError):\n                    pass\n    return '\\n'.join(output)\n",
+      "sample_values": {
+        "nama_fungsi": "format_traceback",
