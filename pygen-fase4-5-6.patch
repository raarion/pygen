+      "code": "class {{nama_class}}:\n    \"\"\"Property-based testing helper. Generate random inputs and verify invariants.\n    Usage:\n        pt = PropertyTester()\n        pt.check(lambda x: abs(x) >= 0, pt.gen_int, 'abs always positive')\n    \"\"\"\n    def __init__(self, seed=None):\n        self._rng = random.Random(seed)\n\n    def gen_int(self, low=-1000, high=1000):\n        return lambda: self._rng.randint(low, high)\n\n    def gen_float(self, low=-1000.0, high=1000.0):\n        return lambda: self._rng.uniform(low, high)\n\n    def gen_string(self, min_len=0, max_len=50):\n        def _gen():\n            length = self._rng.randint(min_len, max_len)\n            chars = 'abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789 '\n            return ''.join(self._rng.choices(chars, k=length))\n        return _gen\n\n    def gen_list(self, element_gen, min_len=0, max_len=20):\n        def _gen():\n            length = self._rng.randint(min_len, max_len)\n            return [element_gen() for _ in range(length)]\n        return _gen\n\n    def gen_choice(self, options):\n        return lambda: self._rng.choice(options)\n\n    def check(self, predicate, generator, label='property', cases={{default_cases}}):\n        \"\"\"Run predicate(generator()) N times. Raises on first failure with counterexample.\"\"\"\n        failures = []\n        for i in range(cases):\n            value = generator()\n            try:\n                result = predicate(value)\n            except Exception as exc:\n                failures.append((i, value, str(exc)))\n                break\n            if not result:\n                failures.append((i, value, 'predicate returned False'))\n                break\n        if failures:\n            idx, val, msg = failures[0]\n            raise AssertionError(\n                'Property \"%s\" failed at case #%d: input=%r, reason=%s' % (label, idx, val, msg)\n            )\n        return True\n\n    def check_no_exception(self, func, generator, label='no_exception', cases={{default_cases}}):\n        \"\"\"Run func(generator()) N times, assert no exception raised.\"\"\"\n        for i in range(cases):\n            value = generator()\n            try:\n                func(value)\n            except Exception as exc:\n                raise AssertionError(\n                    'Property \"%s\" raised %s at case #%d: input=%r' % (label, type(exc).__name__, i, value)\n                )\n        return True\n",
