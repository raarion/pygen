+      "code": "class {{nama_class}}:\n    \"\"\"Thread-safe producer-consumer with bounded queue.\"\"\"\n    def __init__(self, maxsize={{queue_size}}):\n        self._queue = queue.Queue(maxsize=maxsize)\n        self._producers = []\n        self._consumers = []\n        self._running = False\n\n    def add_producer(self, func, *args, **kwargs):\n        \"\"\"Register a producer function. func should call self.put(item).\"\"\"\n        self._producers.append((func, args, kwargs))\n\n    def add_consumer(self, func, *args, **kwargs):\n        \"\"\"Register a consumer function. func gets items via self.get().\"\"\"\n        self._consumers.append((func, args, kwargs))\n\n    def put(self, item, timeout=5):\n        \"\"\"Put item into queue (blocks if full).\"\"\"\n        self._queue.put(item, timeout=timeout)\n\n    def get(self, timeout=5):\n        \"\"\"Get item from queue (blocks if empty). Returns None if stopped.\"\"\"\n        try:\n            return self._queue.get(timeout=timeout)\n        except queue.Empty:\n            return None\n\n    def task_done(self):\n        \"\"\"Signal that a queued task is complete.\"\"\"\n        self._queue.task_done()\n\n    def start(self):\n        \"\"\"Start all producer and consumer threads.\"\"\"\n        self._running = True\n        for func, args, kwargs in self._producers:\n            t = threading.Thread(target=func, args=args, kwargs=kwargs, daemon=True)\n            t.start()\n        for func, args, kwargs in self._consumers:\n            t = threading.Thread(target=func, args=args, kwargs=kwargs, daemon=True)\n            t.start()\n\n    def stop(self):\n        \"\"\"Signal all threads to stop.\"\"\"\n        self._running = False\n\n    @property\n    def is_running(self):\n        return self._running\n\n    @property\n    def size(self):\n        return self._queue.qsize()\n",
