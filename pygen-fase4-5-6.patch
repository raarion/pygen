+        {"name": "nama_fungsi_set", "label": "Nama fungsi setter", "type": "identifier", "default": "safe_setattr"}
+      ],
+      "code": "def {{nama_fungsi}}(obj, path, default=None, separator='.'):\n    \"\"\"Safely get nested attribute or dict key using dot notation.\n    Usage: safe_getattr(obj, 'user.address.city', default='unknown')\n    Works with both object attributes and dict keys.\n    \"\"\"\n    keys = path.split(separator)\n    current = obj\n    for key in keys:\n        try:\n            if isinstance(current, dict):\n                current = current[key]\n            elif isinstance(current, (list, tuple)) and key.isdigit():\n                current = current[int(key)]\n            else:\n                current = getattr(current, key)\n        except (KeyError, IndexError, AttributeError, TypeError):\n            return default\n    return current\n\n\ndef {{nama_fungsi_set}}(obj, path, value, separator='.'):\n    \"\"\"Safely set nested attribute or dict key using dot notation.\n    Creates intermediate dicts if they don't exist.\n    Usage: safe_setattr(config, 'db.connection.host', 'localhost')\n    \"\"\"\n    keys = path.split(separator)\n    current = obj\n    for key in keys[:-1]:\n        if isinstance(current, dict):\n            if key not in current or not isinstance(current[key], (dict,)):\n                current[key] = {}\n            current = current[key]\n        else:\n            try:\n                current = getattr(current, key)\n            except AttributeError:\n                return False\n    last_key = keys[-1]\n    if isinstance(current, dict):\n        current[last_key] = value\n        return True\n    try:\n        setattr(current, last_key, value)\n        return True\n    except (AttributeError, TypeError):\n        return False\n",
+      "sample_values": {
+        "nama_fungsi": "safe_getattr",
+        "nama_fungsi_set": "safe_setattr"
+      }
+    }
