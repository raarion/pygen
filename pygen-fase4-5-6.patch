+      ],
+      "code": "def {{nama_fungsi}}(coroutines, max_concurrency={{max_concurrency}}):\n    \"\"\"Run coroutines concurrently with concurrency limit.\n    Returns list of (result_or_None, exception_or_None) tuples.\n    Usage: results = await async_gather([coro1(), coro2(), ...])\n    \"\"\"\n    semaphore = asyncio.Semaphore(max_concurrency)\n\n    async def _limited(coro):\n        async with semaphore:\n            try:\n                result = await coro\n                return (result, None)\n            except Exception as exc:\n                return (None, exc)\n\n    tasks = [asyncio.ensure_future(_limited(c)) for c in coroutines]\n    return await asyncio.gather(*tasks)\n",
