+      ],
+      "code": "class {{nama_class}}:\n    \"\"\"Newline Delimited JSON (NDJSON/JSONL) reader and writer.\n    Each line is a separate JSON object. Streaming-friendly.\n    \"\"\"\n    def __init__(self, filepath, mode='r', encoding='utf-8'):\n        self.filepath = filepath\n        self.mode = mode\n        self.encoding = encoding\n        self._file = None\n\n    def __enter__(self):\n        self._file = open(self.filepath, self.mode, encoding=self.encoding)\n        return self\n\n    def __exit__(self, *exc):\n        if self._file:\n            self._file.close()\n\n    def read_all(self):\n        \"\"\"Read all lines, parse each as JSON. Returns list of objects.\"\"\"\n        results = []\n        with open(self.filepath, 'r', encoding=self.encoding) as f:\n            for line in f:\n                line = line.strip()\n                if line:\n                    results.append(json.loads(line))\n        return results\n\n    def read_stream(self):\n        \"\"\"Yield parsed JSON objects one by one (generator).\"\"\"\n        with open(self.filepath, 'r', encoding=self.encoding) as f:\n            for line in f:\n                line = line.strip()\n                if line:\n                    yield json.loads(line)\n\n    def write_all(self, items):\n        \"\"\"Write list of objects as NDJSON.\"\"\"\n        with open(self.filepath, 'w', encoding=self.encoding) as f:\n            for item in items:\n                f.write(json.dumps(item, ensure_ascii=False) + '\\n')\n\n    def append(self, item):\n        \"\"\"Append one JSON object as a new line.\"\"\"\n        with open(self.filepath, 'a', encoding=self.encoding) as f:\n            f.write(json.dumps(item, ensure_ascii=False) + '\\n')\n\n    @staticmethod\n    def count_lines(filepath, encoding='utf-8'):\n        \"\"\"Count number of non-empty lines.\"\"\"\n        count = 0\n        with open(filepath, 'r', encoding=encoding) as f:\n            for line in f:\n                if line.strip():\n                    count += 1\n        return count\n",
