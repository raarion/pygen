+        {"name": "max_queued", "label": "Max queued tasks", "type": "int", "default": 100}
+      ],
+      "code": "class {{nama_class}}:\n    \"\"\"Thread pool executor with bounded task queue.\n    Raises RuntimeError if queue is full instead of blocking.\n    \"\"\"\n    class QueueFull(Exception):\n        \"\"\"Raised when the task queue is full.\"\"\"\n        pass\n\n    def __init__(self, max_workers={{max_workers}}, max_queued={{max_queued}}):\n        self._executor = concurrent.futures.ThreadPoolExecutor(max_workers=max_workers)\n        self._semaphore = threading.Semaphore(max_queued)\n\n    def submit(self, fn, *args, **kwargs):\n        \"\"\"Submit task. Raises QueueFull if queue is at capacity.\"\"\"\n        import threading\n        if not self._semaphore.acquire(blocking=False):\n            raise self.QueueFull('Task queue is full')\n        future = self._executor.submit(fn, *args, **kwargs)\n        future.add_done_callback(lambda f: self._semaphore.release())\n        return future\n\n    def map(self, fn, *iterables, timeout=None):\n        \"\"\"Map function across iterables (blocking).\"\"\"\n        return self._executor.map(fn, *iterables, timeout=timeout)\n\n    def shutdown(self, wait=True):\n        \"\"\"Shutdown the executor.\"\"\"\n        self._executor.shutdown(wait=wait)\n\n    def __enter__(self):\n        return self\n\n    def __exit__(self, *exc):\n        self.shutdown()\n",
+      "sample_values": {
+        "nama_class": "BoundedExecutor",
+        "max_workers": 4,
+        "max_queued": 100
+      }
+    },
+    {
+      "id": "debounce",
+      "title": "Debounce Decorator",
+      "description": "Decorator debounce: hanya panggil fungsi setelah idle selama X detik. Thread-safe.",
+      "imports": ["threading", "functools", "time"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_decorator", "label": "Nama decorator", "type": "identifier", "default": "debounce"},
+        {"name": "default_wait", "label": "Default wait detik", "type": "int", "default": 1}
+      ],
+      "code": "def {{nama_decorator}}(wait_seconds={{default_wait}}):\n    \"\"\"Debounce decorator: delay function call until wait_seconds have elapsed\n    since last invocation. Previous pending call is cancelled.\n    \"\"\"\n    def decorator(func):\n        timer = [None]\n        lock = threading.Lock()\n        last_args = [None]\n        last_kwargs = [None]\n\n        def _execute():\n            with lock:\n                args = last_args[0]\n                kwargs = last_kwargs[0]\n                timer[0] = None\n            func(*args, **kwargs)\n\n        @functools.wraps(func)\n        def wrapper(*args, **kwargs):\n            with lock:\n                last_args[0] = args\n                last_kwargs[0] = kwargs\n                if timer[0] is not None:\n                    timer[0].cancel()\n                timer[0] = threading.Timer(wait_seconds, _execute)\n                timer[0].daemon = True\n                timer[0].start()\n\n        wrapper.cancel = lambda: (timer[0].cancel() if timer[0] else None)\n        return wrapper\n    return decorator\n",
+      "sample_values": {
+        "nama_decorator": "debounce",
+        "default_wait": 1
+      }
+    },
+    {
+      "id": "throttle",
+      "title": "Throttle Decorator",
+      "description": "Decorator throttle: batasi fungsi dipanggil maksimal 1x per interval. Thread-safe.",
+      "imports": ["threading", "functools", "time"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_decorator", "label": "Nama decorator", "type": "identifier", "default": "throttle"},
+        {"name": "default_interval", "label": "Default interval detik", "type": "int", "default": 1}
+      ],
+      "code": "def {{nama_decorator}}(interval={{default_interval}}):\n    \"\"\"Throttle decorator: function can only be called once per interval seconds.\n    Calls within the interval are silently dropped.\n    \"\"\"\n    def decorator(func):\n        lock = threading.Lock()\n        last_call = [0.0]\n\n        @functools.wraps(func)\n        def wrapper(*args, **kwargs):\n            now = time.monotonic()\n            with lock:\n                elapsed = now - last_call[0]\n                if elapsed < interval:\n                    return None\n                last_call[0] = now\n            return func(*args, **kwargs)\n\n        def reset():\n            with lock:\n                last_call[0] = 0.0\n\n        wrapper.reset = reset\n        return wrapper\n    return decorator\n",
+      "sample_values": {
+        "nama_decorator": "throttle",
+        "default_interval": 1
+      }
+    }
+  ]
+}
