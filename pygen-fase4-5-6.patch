+      "title": "Line Protocol — NDJSON / JSONL Reader-Writer",
+      "description": "Baca/tulis file JSON per baris (Newline Delimited JSON). Streaming-friendly.",
+      "imports": ["json"],
+      "requires": {},
+      "fields": [
