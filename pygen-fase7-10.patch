@@ -0,0 +1,52 @@
+{
+  "category": "image_utils",
+  "label": "Image Utilities",
+  "templates": [
+    {
+      "id": "image_dimensions",
+      "title": "Get Image Dimensions — width, height, format",
+      "description": "Baca metadata gambar (width, height, format) dari header file. Support PNG, JPEG, GIF, BMP, WebP. Tanpa library eksternal.",
+      "imports": ["struct"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "image_info"}
+      ],
+      "code": "def {{nama_fungsi}}(filepath):\n    \"\"\"Read image dimensions and format from file header.\n    Support: PNG, JPEG, GIF, BMP, WebP.\n    Returns dict: {'width': int, 'height': int, 'format': str} or None if unknown.\n    \"\"\"\n    with open(filepath, 'rb') as f:\n        header = f.read(32)\n    if len(header) < 8:\n        return None\n    # PNG\n    if header[:8] == b'\\x89PNG\\r\\n\\x1a\\n':\n        w = struct.unpack('>I', header[16:20])[0]\n        h = struct.unpack('>I', header[20:24])[0]\n        return {'width': w, 'height': h, 'format': 'PNG'}\n    # GIF\n    if header[:6] in (b'GIF87a', b'GIF89a'):\n        w = struct.unpack('<H', header[6:8])[0]\n        h = struct.unpack('<H', header[8:10])[0]\n        return {'width': w, 'height': h, 'format': 'GIF'}\n    # BMP\n    if header[:2] == b'BM':\n        w = struct.unpack('<i', header[18:22])[0]\n        h = abs(struct.unpack('<i', header[22:26])[0])\n        return {'width': abs(w), 'height': h, 'format': 'BMP'}\n    # WebP\n    if header[:4] == b'RIFF' and header[8:12] == b'WEBP':\n        if header[12:16] == b'VP8 ':\n            w = struct.unpack('<H', header[26:28])[0] & 0x3FFF\n            h = struct.unpack('<H', header[28:30])[0] & 0x3FFF\n        elif header[12:16] == b'VP8L':\n            bits = struct.unpack('<I', header[21:25])[0]\n            w = (bits & 0x3FFF) + 1\n            h = ((bits >> 14) & 0x3FFF) + 1\n        else:\n            w = h = 0\n        return {'width': w, 'height': h, 'format': 'WebP'}\n    # JPEG\n    if header[:2] == b'\\xff\\xd8':\n        return _parse_jpeg(filepath)\n    return None\n\n\ndef _parse_jpeg(filepath):\n    \"\"\"Parse JPEG dimensions by scanning SOF markers.\"\"\"\n    with open(filepath, 'rb') as f:\n        f.read(2)  # skip SOI\n        while True:\n            marker = f.read(2)\n            if len(marker) < 2:\n                break\n            if marker[0] != 0xFF:\n                break\n            mtype = marker[1]\n            if mtype in (0xC0, 0xC1, 0xC2):  # SOF markers\n                f.read(3)  # length + precision\n                h = struct.unpack('>H', f.read(2))[0]\n                w = struct.unpack('>H', f.read(2))[0]\n                return {'width': w, 'height': h, 'format': 'JPEG'}\n            else:\n                length = struct.unpack('>H', f.read(2))[0]\n                f.read(length - 2)\n    return None\n",
+      "sample_values": {
+        "nama_fungsi": "image_info"
+      }
+    },
+    {
+      "id": "is_valid_image",
+      "title": "Validate Image File Header",
+      "description": "Cek magic bytes untuk validasi jenis gambar: PNG, JPEG, GIF, WebP, BMP, TIFF.",
+      "imports": [],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "is_valid_image"},
+        {"name": "nama_fungsi_type", "label": "Nama fungsi deteksi tipe", "type": "identifier", "default": "detect_image_type"}
+      ],
+      "code": "MAGIC_BYTES = [\n    (b'\\x89PNG\\r\\n\\x1a\\n', 'PNG'),\n    (b'\\xff\\xd8\\xff', 'JPEG'),\n    (b'GIF87a', 'GIF'),\n    (b'GIF89a', 'GIF'),\n    (b'BM', 'BMP'),\n    (b'RIFF', 'WebP'),\n    (b'II\\x2a\\x00', 'TIFF'),\n    (b'MM\\x00\\x2a', 'TIFF'),\n]\n\n\ndef {{nama_fungsi_type}}(filepath):\n    \"\"\"Detect image type from file magic bytes.\n    Returns format string ('PNG', 'JPEG', etc.) or None if not recognized.\n    \"\"\"\n    with open(filepath, 'rb') as f:\n        header = f.read(12)\n    if len(header) < 2:\n        return None\n    # WebP special check\n    if header[:4] == b'RIFF' and len(header) >= 12 and header[8:12] == b'WEBP':\n        return 'WebP'\n    for magic, fmt in MAGIC_BYTES:\n        if header[:len(magic)] == magic:\n            if fmt == 'WebP':\n                continue  # handled above\n            return fmt\n    return None\n\n\ndef {{nama_fungsi}}(filepath, expected_format=None):\n    \"\"\"Validate that a file is a valid image.\n    If expected_format is given, checks that the image matches that type.\n    Returns True if valid (and matches expected format if given).\n    \"\"\"\n    fmt = {{nama_fungsi_type}}(filepath)\n    if fmt is None:\n        return False\n    if expected_format:\n        return fmt.lower() == expected_format.lower()\n    return True\n",
+      "sample_values": {
+        "nama_fungsi": "is_valid_image",
+        "nama_fungsi_type": "detect_image_type"
+      }
+    },
+    {
+      "id": "base64_image",
+      "title": "Image → Base64 Data URI",
+      "description": "Encode gambar ke base64 data URI (untuk embedding di HTML/CSS/JSON). Auto-detect format.",
+      "imports": ["base64", "os"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi encode", "type": "identifier", "default": "image_to_data_uri"},
+        {"name": "nama_fungsi_decode", "label": "Nama fungsi decode", "type": "identifier", "default": "data_uri_to_image"}
+      ],
+      "code": "MIME_MAP = {\n    'PNG': 'image/png',\n    'JPEG': 'image/jpeg',\n    'GIF': 'image/gif',\n    'WebP': 'image/webp',\n    'BMP': 'image/bmp',\n    'TIFF': 'image/tiff',\n}\n\n\ndef {{nama_fungsi}}(filepath, mime_type=None):\n    \"\"\"Convert image file to base64 data URI string.\n    Auto-detects MIME type from file header.\n    Usage: <img src=\"{data_uri}\">\n    \"\"\"\n    with open(filepath, 'rb') as f:\n        data = f.read()\n    if mime_type is None:\n        ext = os.path.splitext(filepath)[1].lower().lstrip('.')\n        mime_type = 'image/' + ext if ext else 'application/octet-stream'\n    encoded = base64.b64encode(data).decode('ascii')\n    return 'data:' + mime_type + ';base64,' + encoded\n\n\ndef {{nama_fungsi_decode}}(data_uri, output_path):\n    \"\"\"Decode base64 data URI and save as image file.\n    Returns file size in bytes.\n    \"\"\"\n    if ',' in data_uri:\n        data_uri = data_uri.split(',', 1)[1]\n    data = base64.b64decode(data_uri)\n    with open(output_path, 'wb') as f:\n        f.write(data)\n    return len(data)\n",
+      "sample_values": {
+        "nama_fungsi": "image_to_data_uri",
+        "nama_fungsi_decode": "data_uri_to_image"
+      }
+    }
+  ]
+}
