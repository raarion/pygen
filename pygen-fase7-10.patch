+      "code": "class {{nama_fungsi}}:\n    \"\"\"Descriptor that triggers callbacks on value change.\n    class Config:\n        debug = observable(False)\n    c = Config()\n    c.debug = True  # triggers callbacks\n    \"\"\"\n    def __init__(self, initial_value=None, name=None):\n        self._name = name\n        self._initial = initial_value\n        self._callbacks = []\n\n    def __set_name__(self, owner, name):\n        self._name = name\n\n    def __get__(self, obj, objtype=None):\n        if obj is None:\n            return self\n        return obj.__dict__.get('_obs_' + self._name, self._initial)\n\n    def __set__(self, obj, value):\n        old = self.__get__(obj)\n        obj.__dict__['_obs_' + self._name] = value\n        if old != value:\n            for callback in obj.__dict__.get('_obs_callbacks_' + self._name, []):\n                callback(self._name, old, value)\n\n    def on_change(self, callback):\n        \"\"\"Register a callback for changes. Use as class-level setup.\"\"\"\n        self._callbacks.append(callback)\n        return self\n\n\nclass {{nama_class}}:\n    \"\"\"Mixin that adds observer support for observable properties.\n    class Config(ObservableMixin):\n        name = observable('default')\n    c = Config()\n    c.watch('name', lambda attr, old, new: print(f'{attr}: {old} -> {new}'))\n    \"\"\"\n    def watch(self, attr_name, callback):\n        \"\"\"Watch for changes on an observable attribute.\"\"\"\n        key = '_obs_callbacks_' + attr_name\n        if key not in self.__dict__:\n            self.__dict__[key] = []\n        self.__dict__[key].append(callback)\n\n    def unwatch(self, attr_name, callback=None):\n        \"\"\"Remove callback(s) for an attribute.\"\"\"\n        key = '_obs_callbacks_' + attr_name\n        if callback:\n            self.__dict__.get(key, []).remove(callback)\n        else:\n            self.__dict__.pop(key, None)\n",
