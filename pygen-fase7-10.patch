+      "code": "class {{nama_metaclass}}(type):\n    \"\"\"Singleton metaclass. Usage: class MyClass(metaclass=SingletonMeta): ...\n    Only one instance of MyClass can ever exist.\n    \"\"\"\n    _instances = {}\n\n    def __call__(cls, *args, **kwargs):\n        if cls not in cls._instances:\n            cls._instances[cls] = super().__call__(*args, **kwargs)\n        return cls._instances[cls]\n\n    @classmethod\n    def reset(mcs, cls):\n        \"\"\"Reset the singleton instance (useful for testing).\"\"\"\n        mcs._instances.pop(cls, None)\n\n\ndef {{nama_decorator}}(cls):\n    \"\"\"Singleton decorator alternative. Usage: @singleton class MyClass: ...\n    Wraps __init__ to prevent re-initialization.\n    \"\"\"\n    instances = {}\n    original_init = cls.__init__\n\n    @functools.wraps(cls.__init__)\n    def __init__(self, *args, **kwargs):\n        if not getattr(self, '_initialized', False):\n            original_init(self, *args, **kwargs)\n            self._initialized = True\n\n    cls.__init__ = __init__\n\n    original_new = cls.__new__ if hasattr(cls, '__new__') and cls.__new__ is not object.__new__ else None\n\n    def __new__(klass, *args, **kwargs):\n        if cls not in instances:\n            if original_new:\n                instance = original_new(klass)\n            else:\n                instance = object.__new__(klass)\n            instances[cls] = instance\n        return instances[cls]\n\n    cls.__new__ = __new__\n    cls._reset_singleton = lambda: instances.pop(cls, None)\n    return cls\n",
