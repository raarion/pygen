+        {"name": "nama_class", "label": "Nama class", "type": "identifier", "default": "OneHotEncoder"}
+      ],
+      "code": "class {{nama_class}}:\n    \"\"\"One-hot encoder for categorical data.\n    encoder = OneHotEncoder()\n    encoder.fit(['cat', 'dog', 'bird'])\n    encoder.transform(['cat', 'bird']) → [[1,0,0], [0,0,1]]\n    \"\"\"\n    def __init__(self):\n        self.classes_ = []\n        self._class_to_idx = {}\n\n    def fit(self, categories):\n        \"\"\"Learn categories from data.\"\"\"\n        self.classes_ = sorted(set(categories))\n        self._class_to_idx = {c: i for i, c in enumerate(self.classes_)}\n        return self\n\n    def transform(self, data):\n        \"\"\"Transform categories to one-hot vectors.\"\"\"\n        result = []\n        for item in data:\n            vec = [0] * len(self.classes_)\n            if item in self._class_to_idx:\n                vec[self._class_to_idx[item]] = 1\n            result.append(vec)\n        return result\n\n    def fit_transform(self, data):\n        \"\"\"Fit and transform in one step.\"\"\"\n        self.fit(data)\n        return self.transform(data)\n\n    def inverse_transform(self, vectors):\n        \"\"\"Convert one-hot vectors back to categories.\"\"\"\n        result = []\n        for vec in vectors:\n            idx = vec.index(1) if 1 in vec else -1\n            if 0 <= idx < len(self.classes_):\n                result.append(self.classes_[idx])\n            else:\n                result.append(None)\n        return result\n\n    @property\n    def n_classes(self):\n        return len(self.classes_)\n",
