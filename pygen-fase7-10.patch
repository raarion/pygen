+      "id": "confusion_matrix",
+      "title": "Confusion Matrix Builder",
+      "description": "Bangun confusion matrix dari y_true dan y_pred. Support multi-class. stdlib only.",
+      "imports": [],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "confusion_matrix"},
+        {"name": "nama_fungsi_print", "label": "Nama fungsi printer", "type": "identifier", "default": "print_cm"}
+      ],
+      "code": "def {{nama_fungsi}}(y_true, y_pred, labels=None):\n    \"\"\"Build confusion matrix from true and predicted labels.\n    Returns dict: {'matrix': 2D list, 'labels': list, 'size': int}\n    matrix[i][j] = count where true=i, pred=j\n    \"\"\"\n    if labels is None:\n        labels = sorted(set(y_true) | set(y_pred))\n    label_idx = {label: i for i, label in enumerate(labels)}\n    n = len(labels)\n    matrix = [[0] * n for _ in range(n)]\n    for t, p in zip(y_true, y_pred):\n        if t in label_idx and p in label_idx:\n            matrix[label_idx[t]][label_idx[p]] += 1\n    return {'matrix': matrix, 'labels': labels, 'size': n}\n\n\ndef {{nama_fungsi_print}}(cm_result):\n    \"\"\"Pretty-print confusion matrix.\"\"\"\n    matrix = cm_result['matrix']\n    labels = cm_result['labels']\n    max_label = max(len(str(l)) for l in labels) if labels else 3\n    max_val = max(max(row) for row in matrix) if matrix else 0\n    cell_width = max(max_label + 1, len(str(max_val)) + 2)\n    header = ' ' * (max_label + 2) + ''.join(str(l).rjust(cell_width) for l in labels)\n    print('Predicted →')\n    print(header)\n    print('Actual ↓')\n    for i, label in enumerate(labels):\n        row_str = str(label).ljust(max_label + 2) + ''.join(str(matrix[i][j]).rjust(cell_width) for j in range(len(labels)))\n        print(row_str)\n",
