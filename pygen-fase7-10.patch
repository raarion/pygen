+      "code": "class {{nama_class}}:\n    \"\"\"ASCII progress bar with percentage and optional ETA.\"\"\"\n    def __init__(self, total, width={{bar_width}}, fill='{{fill_char}}', empty='{{empty_char}}', prefix='', suffix=''):\n        self.total = total\n        self.width = width\n        self.fill = fill\n        self.empty = empty\n        self.prefix = prefix\n        self.suffix = suffix\n        self.current = 0\n        self._start_time = None\n\n    def update(self, amount=1):\n        \"\"\"Advance progress bar by amount.\"\"\"\n        if self._start_time is None:\n            self._start_time = time.time()\n        self.current = min(self.current + amount, self.total)\n        self._draw()\n\n    def _draw(self):\n        pct = self.current / self.total if self.total else 1\n        filled = int(self.width * pct)\n        bar = self.fill * filled + self.empty * (self.width - filled)\n        pct_str = '%.1f%%' % (pct * 100)\n        eta_str = ''\n        if self._start_time and self.current > 0:\n            elapsed = time.time() - self._start_time\n            rate = self.current / elapsed\n            remaining = (self.total - self.current) / rate if rate > 0 else 0\n            if remaining > 1:\n                eta_str = ' ETA: %ds' % int(remaining)\n        line = '\\r%s |%s| %s %s/%s%s' % (self.prefix, bar, pct_str, self.current, self.total, eta_str)\n        if self.suffix:\n            line += ' ' + self.suffix\n        sys.stderr.write(line)\n        if self.current >= self.total:\n            sys.stderr.write('\\n')\n        sys.stderr.flush()\n\n    def __enter__(self):\n        self._start_time = time.time()\n        return self\n\n    def __exit__(self, *exc):\n        if self.current < self.total:\n            sys.stderr.write('\\n')\n",
