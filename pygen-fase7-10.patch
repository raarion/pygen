+      "code": "def {{nama_fungsi}}(y_true, y_pred):\n    \"\"\"Calculate regression metrics: R², MSE, RMSE, MAE.\n    Returns dict with all metrics.\n    \"\"\"\n    n = len(y_true)\n    if n == 0:\n        return {'r2': 0, 'mse': 0, 'rmse': 0, 'mae': 0}\n    mean_y = sum(y_true) / n\n    ss_res = sum((yt - yp) ** 2 for yt, yp in zip(y_true, y_pred))\n    ss_tot = sum((yt - mean_y) ** 2 for yt in y_true)\n    mse = ss_res / n\n    rmse = mse ** 0.5\n    mae = sum(abs(yt - yp) for yt, yp in zip(y_true, y_pred)) / n\n    r2 = 1 - (ss_res / ss_tot) if ss_tot > 1e-10 else 0.0\n    return {\n        'r2': round(r2, 6),\n        'mse': round(mse, 6),\n        'rmse': round(rmse, 6),\n        'mae': round(mae, 6),\n        'n_samples': n,\n    }\n",
