+      "code": "class {{nama_class_std}}:\n    \"\"\"Standard scaler: z-score normalization. x' = (x - mean) / std\n    scaler = StandardScaler()\n    scaler.fit([[1,2],[3,4],[5,6]])\n    scaled = scaler.transform([[2,3]])\n    \"\"\"\n    def __init__(self):\n        self.mean_ = None\n        self.std_ = None\n\n    def fit(self, data):\n        \"\"\"Compute mean and std per feature column.\"\"\"\n        if not data:\n            return self\n        n_features = len(data[0])\n        self.mean_ = [0.0] * n_features\n        self.std_ = [0.0] * n_features\n        n = len(data)\n        for row in data:\n            for j in range(n_features):\n                self.mean_[j] += row[j]\n        self.mean_ = [m / n for m in self.mean_]\n        for row in data:\n            for j in range(n_features):\n                self.std_[j] += (row[j] - self.mean_[j]) ** 2\n        self.std_ = [(s / n) ** 0.5 for s in self.std_]\n        self.std_ = [s if s > 1e-10 else 1.0 for s in self.std_]\n        return self\n\n    def transform(self, data):\n        return [[(x - self.mean_[j]) / self.std_[j] for j, x in enumerate(row)] for row in data]\n\n    def fit_transform(self, data):\n        self.fit(data)\n        return self.transform(data)\n\n    def inverse_transform(self, data):\n        return [[x * self.std_[j] + self.mean_[j] for j, x in enumerate(row)] for row in data]\n\n\nclass {{nama_class_minmax}}:\n    \"\"\"Min-Max scaler: scale to [0, 1]. x' = (x - min) / (max - min)\"\"\"\n    def __init__(self, feature_range=(0, 1)):\n        self.min_ = None\n        self.max_ = None\n        self.range = feature_range\n\n    def fit(self, data):\n        if not data:\n            return self\n        n_features = len(data[0])\n        self.min_ = [min(row[j] for row in data) for j in range(n_features)]\n        self.max_ = [max(row[j] for row in data) for j in range(n_features)]\n        return self\n\n    def transform(self, data):\n        lo, hi = self.range\n        result = []\n        for row in data:\n            scaled = []\n            for j, x in enumerate(row):\n                rng = self.max_[j] - self.min_[j]\n                if rng < 1e-10:\n                    scaled.append(lo)\n                else:\n                    scaled.append(lo + (x - self.min_[j]) / rng * (hi - lo))\n            result.append(scaled)\n        return result\n\n    def fit_transform(self, data):\n        self.fit(data)\n        return self.transform(data)\n",
