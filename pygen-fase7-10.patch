@@ -0,0 +1,134 @@
+{
+  "category": "metaprogramming",
+  "label": "Metaprogramming",
+  "templates": [
+    {
+      "id": "class_factory",
+      "title": "Dynamic Class Factory",
+      "description": "Buat class baru secara dinamis dari dict attributes. Bisa specify bases, methods, class vars.",
+      "imports": [],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi factory", "type": "identifier", "default": "make_class"},
+        {"name": "nama_fungsi_ext", "label": "Nama fungsi (extended with methods)", "type": "identifier", "default": "build_class"}
+      ],
+      "code": "def {{nama_fungsi}}(name, bases=(), **attrs):\n    \"\"\"Create a new class dynamically.\n    make_class('Dog', (Animal,), sound='Woof')\n    \"\"\"\n    return type(name, bases, attrs)\n\n\ndef {{nama_fungsi_ext}}(name, fields=None, methods=None, bases=(), doc=None):\n    \"\"\"Build a class with fields (class vars) and methods.\n    fields: dict of name: default_value\n    methods: dict of name: callable\n    Returns the new class.\n    \"\"\"\n    attrs = {}\n    if doc:\n        attrs['__doc__'] = doc\n    if fields:\n        for fname, default in fields.items():\n            attrs[fname] = default\n    if methods:\n        attrs.update(methods)\n\n    def __init__(self, **kwargs):\n        for key, val in (fields or {}).items():\n            setattr(self, key, kwargs.get(key, val))\n    attrs.setdefault('__init__', __init__)\n\n    def __repr__(self):\n        parts = ['%s=%r' % (k, getattr(self, k, None)) for k in (fields or {})]\n        return self.__class__.__name__ + '(' + ', '.join(parts) + ')'\n    attrs.setdefault('__repr__', __repr__)\n\n    return type(name, bases, attrs)\n",
+      "sample_values": {
+        "nama_fungsi": "make_class",
+        "nama_fungsi_ext": "build_class"
+      }
+    },
+    {
+      "id": "dataclass_generator",
+      "title": "Dataclass Code Generator",
+      "description": "Generate kode @dataclass dari field definitions. Output string Python siap simpan.",
+      "imports": [],
+      "requires": {"python": ">=3.7"},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi generator", "type": "identifier", "default": "generate_dataclass"},
+        {"name": "use_annotations", "label": "Use type annotations", "type": "bool", "default": true}
+      ],
+      "code": "def {{nama_fungsi}}(class_name, fields, use_annotations={{use_annotations}}, frozen=False, slots=False):\n    \"\"\"Generate @dataclass Python code from field definitions.\n    fields: list of {'name': str, 'type': str, 'default': any, 'required': bool}\n    Returns Python source code as string.\n    \"\"\"\n    imports = ['from dataclasses import dataclass']\n    if any(f.get('type') in ('List', 'Dict', 'Optional') for f in fields):\n        imports.append('from typing import List, Dict, Optional')\n    lines = list(imports) + ['', '@dataclass(frozen=' + str(frozen) + (', slots=True' if slots else '') + ')']\n    lines.append('class ' + class_name + ':')\n    has_doc = False\n    for f in fields:\n        if f.get('doc'):\n            lines.append('    \"\"\"' + f['doc'] + '\"\"\"')\n            has_doc = True\n            break\n    required = [f for f in fields if f.get('required', True)]\n    optional = [f for f in fields if not f.get('required', True)]\n    for f in required + optional:\n        name = f['name']\n        ftype = f.get('type', 'str')\n        if use_annotations:\n            if 'default' in f and f['default'] is not None:\n                default_repr = repr(f['default'])\n                lines.append('    %s: %s = %s' % (name, ftype, default_repr))\n            else:\n                lines.append('    %s: %s' % (name, ftype))\n        else:\n            if 'default' in f and f['default'] is not None:\n                lines.append('    %s = %r' % (name, f['default']))\n            else:\n                lines.append('    %s = None' % name)\n    if not fields and not has_doc:\n        lines.append('    pass')\n    return '\\n'.join(lines) + '\\n'\n",
