+      ],
+      "code": "def {{nama_decorator}}(cls=None, hide_private=True, max_items=None):\n    \"\"\"Auto-generate __repr__ from instance attributes.\n    @auto_repr\n    class Point:\n        def __init__(self, x, y):\n            self.x = x\n            self.y = y\n    repr(Point(1, 2)) → 'Point(x=1, y=2)'\n    \"\"\"\n    def decorator(klass):\n        def __repr__(self):\n            attrs = vars(self)\n            if hide_private:\n                attrs = {k: v for k, v in attrs.items() if not k.startswith('_')}\n            parts = []\n            for k, v in attrs.items():\n                if max_items and len(parts) >= max_items:\n                    parts.append('...')\n                    break\n                parts.append('%s=%r' % (k, v))\n            return klass.__name__ + '(' + ', '.join(parts) + ')'\n        klass.__repr__ = __repr__\n        return klass\n\n    if cls is not None:\n        return decorator(cls)\n    return decorator\n\n\ndef {{nama_decorator_str}}(cls=None, **kwargs):\n    \"\"\"Like auto_repr but also sets __str__ = __repr__.\"\"\"\n    def decorator(klass):\n        klass = {{nama_decorator}}(cls=klass, **kwargs)\n        klass.__str__ = klass.__repr__\n        return klass\n    if cls is not None:\n        return decorator(cls)\n    return decorator\n",
