+++ b/pygen/templates/document/document.json
@@ -0,0 +1,116 @@
+{
+  "category": "document",
+  "label": "Document Processing",
+  "templates": [
+    {
+      "id": "word_counter",
+      "title": "Document Word/Char/Line Counter",
+      "description": "Statistik teks: kata, karakter, baris, paragraf, kalimat. Seperti wc tapi lebih lengkap.",
+      "imports": ["re"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "count_text"},
+        {"name": "nama_fungsi_file", "label": "Nama fungsi (dari file)", "type": "identifier", "default": "count_file"}
+      ],
+      "code": "def {{nama_fungsi}}(text):\n    \"\"\"Count text statistics: chars, words, lines, paragraphs, sentences.\"\"\"\n    chars = len(text)\n    chars_no_space = len(text.replace(' ', '').replace('\\n', '').replace('\\t', ''))\n    words = len(text.split())\n    lines = text.count('\\n') + (1 if text and not text.endswith('\\n') else 0)\n    paragraphs = len([p for p in text.split('\\n\\n') if p.strip()]) if text.strip() else 0\n    sentences = len([s for s in re.split(r'[.!?]+', text) if s.strip()])\n    return {\n        'characters': chars,\n        'characters_no_spaces': chars_no_space,\n        'words': words,\n        'lines': lines,\n        'paragraphs': paragraphs,\n        'sentences': sentences,\n    }\n\n\ndef {{nama_fungsi_file}}(filepath, encoding='utf-8'):\n    \"\"\"Count statistics from a text file.\"\"\"\n    with open(filepath, 'r', encoding=encoding) as f:\n        text = f.read()\n    return {{nama_fungsi}}(text)\n",
+      "sample_values": {
+        "nama_fungsi": "count_text",
+        "nama_fungsi_file": "count_file"
+      }
+    },
+    {
+      "id": "markdown_to_text",
+      "title": "Markdown → Plain Text",
+      "description": "Strip markdown formatting dari teks. Headers, bold, italic, links, code → plain text.",
+      "imports": ["re"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "markdown_to_text"}
+      ],
+      "code": "def {{nama_fungsi}}(markdown_text):\n    \"\"\"Convert Markdown to plain text. Strips formatting.\n    Handles: headers, bold, italic, links, images, code, lists, blockquotes.\n    \"\"\"\n    text = markdown_text\n    # Images: ![alt](url) → alt\n    text = re.sub(r'!\\[([^\\]]*)\\]\\([^\\)]*\\)', r'\\1', text)\n    # Links: [text](url) → text\n    text = re.sub(r'\\[([^\\]]*)\\]\\([^\\)]*\\)', r'\\1', text)\n    # Headers: ### Title → Title\n    text = re.sub(r'^#{1,6}\\s+', '', text, flags=re.MULTILINE)\n    # Bold: **text** or __text__ → text\n    text = re.sub(r'\\*\\*(.+?)\\*\\*', r'\\1', text)\n    text = re.sub(r'__(.+?)__', r'\\1', text)\n    # Italic: *text* or _text_ → text\n    text = re.sub(r'\\*(.+?)\\*', r'\\1', text)\n    text = re.sub(r'(?<!\\w)_(.+?)_(?!\\w)', r'\\1', text)\n    # Inline code: `code` → code\n    text = re.sub(r'`(.+?)`', r'\\1', text)\n    # Code blocks: ```code``` → code\n    text = re.sub(r'```[\\s\\S]*?```', '', text)\n    # Blockquotes: > text → text\n    text = re.sub(r'^>\\s?', '', text, flags=re.MULTILINE)\n    # List markers: - item or 1. item → item\n    text = re.sub(r'^[\\s]*[-*+]\\s+', '', text, flags=re.MULTILINE)\n    text = re.sub(r'^[\\s]*\\d+\\.\\s+', '', text, flags=re.MULTILINE)\n    # Horizontal rules\n    text = re.sub(r'^[-*_]{3,}\\s*$', '', text, flags=re.MULTILINE)\n    # Collapse multiple blank lines\n    text = re.sub(r'\\n{3,}', '\\n\\n', text)\n    return text.strip()\n",
+      "sample_values": {
+        "nama_fungsi": "markdown_to_text"
+      }
+    },
+    {
+      "id": "html_to_text",
+      "title": "HTML → Plain Text",
+      "description": "Strip HTML tags, decode entities. stdlib html.parser.",
+      "imports": ["html.parser", "html"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_class", "label": "Nama class parser", "type": "identifier", "default": "HTMLTextExtractor"},
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "html_to_text"}
+      ],
+      "code": "class {{nama_class}}(html.parser.HTMLParser):\n    \"\"\"Extract text from HTML, skipping tags and scripts.\"\"\"\n    SKIP_TAGS = {'script', 'style', 'head'}\n\n    def __init__(self):\n        super().__init__()\n        self._result = []\n        self._skip_depth = 0\n\n    def handle_starttag(self, tag, attrs):\n        if tag.lower() in self.SKIP_TAGS:\n            self._skip_depth += 1\n        if tag.lower() in ('br', 'p', 'div', 'li', 'tr', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6'):\n            self._result.append('\\n')\n\n    def handle_endtag(self, tag):\n        if tag.lower() in self.SKIP_TAGS:\n            self._skip_depth = max(0, self._skip_depth - 1)\n        if tag.lower() in ('p', 'div', 'table', 'h1', 'h2', 'h3', 'h4', 'h5', 'h6'):\n            self._result.append('\\n')\n\n    def handle_data(self, data):\n        if self._skip_depth == 0:\n            self._result.append(data)\n\n    def get_text(self):\n        import re\n        text = ''.join(self._result)\n        text = re.sub(r'\\n{3,}', '\\n\\n', text)\n        return text.strip()\n\n\ndef {{nama_fungsi}}(html_text):\n    \"\"\"Convert HTML to plain text. Strips tags, decodes entities.\"\"\"\n    parser = {{nama_class}}()\n    parser.feed(html_text)\n    text = parser.get_text()\n    return html.unescape(text)\n",
+      "sample_values": {
+        "nama_class": "HTMLTextExtractor",
+        "nama_fungsi": "html_to_text"
+      }
+    },
+    {
+      "id": "text_to_blocks",
+      "title": "Split Text into Paragraph Blocks",
+      "description": "Pisah teks jadi list paragraf. Support custom separator dan minimum length.",
+      "imports": ["re"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "text_to_blocks"},
+        {"name": "nama_fungsi_chunks", "label": "Nama fungsi chunk by size", "type": "identifier", "default": "chunk_text"}
+      ],
+      "code": "def {{nama_fungsi}}(text, separator='\\\\n\\\\n', min_length=1):\n    \"\"\"Split text into paragraph blocks.\n    separator: regex pattern for block boundaries (default: blank lines).\n    min_length: minimum block length to include.\n    \"\"\"\n    blocks = re.split(separator, text)\n    return [b.strip() for b in blocks if len(b.strip()) >= min_length]\n\n\ndef {{nama_fungsi_chunks}}(text, max_chars=1000, overlap=100):\n    \"\"\"Split text into overlapping chunks by character count.\n    Tries to break at sentence boundaries.\n    \"\"\"\n    if len(text) <= max_chars:\n        return [text]\n    sentences = re.split(r'(?<=[.!?])\\s+', text)\n    chunks = []\n    current = ''\n    for sentence in sentences:\n        if len(current) + len(sentence) + 1 > max_chars and current:\n            chunks.append(current.strip())\n            # Keep overlap\n            if overlap > 0 and len(current) > overlap:\n                current = current[-overlap:] + ' ' + sentence\n            else:\n                current = sentence\n        else:\n            current = (current + ' ' + sentence).strip()\n    if current.strip():\n        chunks.append(current.strip())\n    return chunks\n",
+      "sample_values": {
+        "nama_fungsi": "text_to_blocks",
+        "nama_fungsi_chunks": "chunk_text"
+      }
+    },
+    {
+      "id": "keyword_extractor",
+      "title": "Simple Keyword Extractor (TF-based)",
+      "description": "Ekstrak kata kunci dari teks berdasarkan Term Frequency. Tanpa library eksternal.",
+      "imports": ["re", "collections"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "extract_keywords"},
+        {"name": "default_top_n", "label": "Default top N keywords", "type": "int", "default": 10},
+        {"name": "min_word_length", "label": "Min word length", "type": "int", "default": 3}
+      ],
+      "code": "STOP_WORDS = {'the', 'and', 'for', 'are', 'but', 'not', 'you', 'all', 'can', 'had', 'her', 'was', 'one', 'our', 'out', 'has', 'have', 'been', 'this', 'that', 'with', 'from', 'they', 'will', 'what', 'when', 'where', 'which', 'their', 'there', 'about', 'would', 'could', 'should', 'also', 'into', 'more', 'some', 'than', 'other', 'these', 'just', 'over', 'such', 'take', 'each', 'very', 'may', 'its', 'only', 'known', 'after', 'certain'}\n\n\ndef {{nama_fungsi}}(text, top_n={{default_top_n}}, min_length={{min_word_length}}, stop_words=None):\n    \"\"\"Extract top keywords from text based on term frequency.\n    Returns list of (word, count) tuples sorted by frequency.\n    \"\"\"\n    stops = stop_words if stop_words is not None else STOP_WORDS\n    words = re.findall(r'\\b[a-zA-Z]+\\b', text.lower())\n    filtered = [w for w in words if len(w) >= min_length and w not in stops]\n    freq = collections.Counter(filtered)\n    return freq.most_common(top_n)\n\n\ndef extract_keyphrases(text, ngram_size=2, top_n=10):\n    \"\"\"Extract top keyphrases (n-grams) from text.\n    Returns list of (phrase, count) tuples.\n    \"\"\"\n    words = re.findall(r'\\b[a-zA-Z]+\\b', text.lower())\n    filtered = [w for w in words if w not in STOP_WORDS]\n    ngrams = collections.Counter()\n    for i in range(len(filtered) - ngram_size + 1):\n        phrase = ' '.join(filtered[i:i + ngram_size])\n        ngrams[phrase] += 1\n    return ngrams.most_common(top_n)\n",
+      "sample_values": {
+        "nama_fungsi": "extract_keywords",
+        "default_top_n": 10,
+        "min_word_length": 3
+      }
+    },
+    {
+      "id": "text_summary",
+      "title": "Text Summarizer (Extractive)",
+      "description": "Ringkas teks dengan memilih kalimat paling penting berdasarkan TF. Stdlib only.",
+      "imports": ["re", "collections"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "summarize"},
+        {"name": "default_ratio", "label": "Default ratio (0.0-1.0)", "type": "text", "default": "0.3"}
+      ],
+      "code": "def {{nama_fungsi}}(text, num_sentences=None, ratio={{default_ratio}}):\n    \"\"\"Extractive text summarizer using sentence scoring.\n    Scores sentences by word frequency (TF-based).\n    num_sentences: fixed number of sentences to keep.\n    ratio: fraction of original sentences to keep (0.0-1.0).\n    Returns summarized text.\n    \"\"\"\n    sentences = re.split(r'(?<=[.!?])\\s+', text.strip())\n    if len(sentences) <= 2:\n        return text.strip()\n    # Word frequencies\n    words = re.findall(r'\\b[a-zA-Z]+\\b', text.lower())\n    stop = {'the', 'a', 'an', 'is', 'are', 'was', 'were', 'be', 'been', 'being',\n            'have', 'has', 'had', 'do', 'does', 'did', 'will', 'would', 'could',\n            'should', 'may', 'might', 'can', 'to', 'of', 'in', 'for', 'on', 'with',\n            'at', 'by', 'from', 'as', 'into', 'through', 'during', 'and', 'but',\n            'or', 'not', 'no', 'if', 'it', 'its', 'this', 'that'}\n    freq = collections.Counter(w for w in words if w not in stop and len(w) > 2)\n    # Score sentences\n    scored = []\n    for i, sent in enumerate(sentences):\n        sent_words = re.findall(r'\\b[a-zA-Z]+\\b', sent.lower())\n        score = sum(freq.get(w, 0) for w in sent_words)\n        # Normalize by sentence length\n        score = score / max(len(sent_words), 1)\n        # Slight boost for early sentences\n        if i < 3:\n            score *= 1.2\n        scored.append((i, score, sent))\n    # Select top sentences\n    if num_sentences is None:\n        num_sentences = max(1, int(len(sentences) * float(ratio)))\n    top = sorted(scored, key=lambda x: x[1], reverse=True)[:num_sentences]\n    # Restore original order\n    top.sort(key=lambda x: x[0])\n    return ' '.join(s[2] for s in top)\n",
+      "sample_values": {
+        "nama_fungsi": "summarize",
+        "default_ratio": "0.3"
+      }
+    },
+    {
+      "id": "readability_score",
+      "title": "Readability Score — Flesch-Kincaid",
+      "description": "Hitung skor keterbacaan teks: Flesch Reading Ease, Flesch-Kincaid Grade Level, Gunning Fog.",
+      "imports": ["re"],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "readability_scores"}
+      ],
+      "code": "def {{nama_fungsi}}(text):\n    \"\"\"Calculate readability scores for English text.\n    Returns dict with: flesch_reading_ease, flesch_kincaid_grade, gunning_fog,\n    word_count, sentence_count, syllable_count.\n    \"\"\"\n    sentences = [s.strip() for s in re.split(r'[.!?]+', text) if s.strip()]\n    words = re.findall(r'[a-zA-Z]+', text)\n    num_sentences = max(len(sentences), 1)\n    num_words = max(len(words), 1)\n    num_syllables = sum(_count_syllables(w) for w in words)\n    # Flesch Reading Ease\n    fre = 206.835 - 1.015 * (num_words / num_sentences) - 84.6 * (num_syllables / num_words)\n    # Flesch-Kincaid Grade Level\n    fkgl = 0.39 * (num_words / num_sentences) + 11.8 * (num_syllables / num_words) - 15.59\n    # Gunning Fog Index\n    complex_words = sum(1 for w in words if _count_syllables(w) >= 3)\n    fog = 0.4 * ((num_words / num_sentences) + 100 * (complex_words / num_words))\n    return {\n        'flesch_reading_ease': round(fre, 2),\n        'flesch_kincaid_grade': round(fkgl, 2),\n        'gunning_fog': round(fog, 2),\n        'word_count': num_words,\n        'sentence_count': num_sentences,\n        'avg_words_per_sentence': round(num_words / num_sentences, 2),\n        'avg_syllables_per_word': round(num_syllables / num_words, 2),\n    }\n\n\ndef _count_syllables(word):\n    \"\"\"Estimate syllable count for an English word.\"\"\"\n    word = word.lower()\n    if len(word) <= 3:\n        return 1\n    word = re.sub(r'(?:[^laeiouy]es|ed|[^laeiouy]e)$', '', word)\n    word = re.sub(r'^y', '', word)\n    vowels = re.findall(r'[aeiouy]+', word)\n    return max(len(vowels), 1)\n",
+      "sample_values": {
+        "nama_fungsi": "readability_scores"
+      }
+    }
+  ]
+}
