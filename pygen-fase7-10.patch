+      "code": "def {{nama_fungsi_roc}}(y_true, y_scores):\n    \"\"\"Compute ROC curve points (FPR, TPR) at various thresholds.\n    y_true: binary labels (0/1).\n    y_scores: predicted scores/probabilities.\n    Returns dict with 'fpr', 'tpr', 'thresholds' lists.\n    \"\"\"\n    pairs = sorted(zip(y_scores, y_true), reverse=True)\n    total_pos = sum(1 for _, y in pairs if y == 1)\n    total_neg = sum(1 for _, y in pairs if y == 0)\n    if total_pos == 0 or total_neg == 0:\n        return {'fpr': [0, 1], 'tpr': [0, 1], 'thresholds': []}\n    fpr_list, tpr_list, thresholds = [0.0], [0.0], []\n    tp, fp = 0, 0\n    for score, label in pairs:\n        if label == 1:\n            tp += 1\n        else:\n            fp += 1\n        tpr_list.append(tp / total_pos)\n        fpr_list.append(fp / total_neg)\n        thresholds.append(score)\n    return {'fpr': fpr_list, 'tpr': tpr_list, 'thresholds': thresholds}\n\n\ndef {{nama_fungsi}}(y_true, y_scores):\n    \"\"\"Compute AUC-ROC using trapezoidal rule.\n    Returns float between 0 and 1.\n    \"\"\"\n    roc = {{nama_fungsi_roc}}(y_true, y_scores)\n    fpr = roc['fpr']\n    tpr = roc['tpr']\n    auc = 0.0\n    for i in range(1, len(fpr)):\n        auc += (fpr[i] - fpr[i-1]) * (tpr[i] + tpr[i-1]) / 2.0\n    return round(auc, 6)\n",
