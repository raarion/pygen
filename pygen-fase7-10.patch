+      "code": "def {{nama_fungsi}}(cls, interface):\n    \"\"\"Check if cls implements all public methods of interface.\n    Returns dict with 'complete' (bool), 'missing' (list), 'matches' (list).\n    \"\"\"\n    required = set()\n    for name, method in inspect.getmembers(interface, predicate=inspect.isfunction):\n        if not name.startswith('_'):\n            required.add(name)\n    implemented = set()\n    for name in required:\n        if hasattr(cls, name) and callable(getattr(cls, name, None)):\n            implemented.add(name)\n    missing = required - implemented\n    return {\n        'complete': len(missing) == 0,\n        'missing': sorted(missing),\n        'matches': sorted(implemented),\n        'required': sorted(required),\n    }\n\n\ndef {{nama_decorator}}(interface):\n    \"\"\"Decorator that validates a class implements an interface at definition time.\n    Raises TypeError if any methods are missing.\n    Usage: @implements(MyInterface) class MyClass: ...\n    \"\"\"\n    def decorator(cls):\n        result = {{nama_fungsi}}(cls, interface)\n        if not result['complete']:\n            raise TypeError('%s does not implement %s. Missing: %s' % (\n                cls.__name__, interface.__name__, ', '.join(result['missing'])\n            ))\n        cls.__implements__ = interface\n        return cls\n    return decorator\n",
