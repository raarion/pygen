+      ],
+      "code": "class {{nama_class}}:\n    \"\"\"Simple IoC container for dependency injection.\n    c = Container()\n    c.register('db', Database('localhost'))\n    c.register('cache', Cache())\n    @c.inject\n    def handler(db, cache):\n        ...\n    \"\"\"\n    def __init__(self):\n        self._registry = {}\n        self._factories = {}\n\n    def register(self, name, instance):\n        \"\"\"Register a pre-built instance.\"\"\"\n        self._registry[name] = instance\n        return self\n\n    def register_factory(self, name, factory):\n        \"\"\"Register a factory function (called lazily, result cached).\"\"\"\n        self._factories[name] = factory\n        return self\n\n    def get(self, name, default=None):\n        \"\"\"Get a registered dependency by name.\"\"\"\n        if name in self._registry:\n            return self._registry[name]\n        if name in self._factories:\n            self._registry[name] = self._factories[name]()\n            del self._factories[name]\n            return self._registry[name]\n        return default\n\n    def inject(self, func):\n        \"\"\"Decorator: inject registered dependencies into function parameters.\"\"\"\n        @functools.wraps(func)\n        def wrapper(*args, **kwargs):\n            sig = inspect.signature(func)\n            for param_name, param in sig.parameters.items():\n                if param_name not in kwargs and param_name not in ('args', 'kwargs'):\n                    dep = self.get(param_name)\n                    if dep is not None:\n                        kwargs[param_name] = dep\n            return func(*args, **kwargs)\n        return wrapper\n\n    def has(self, name):\n        return name in self._registry or name in self._factories\n\n    def clear(self):\n        self._registry.clear()\n        self._factories.clear()\n",
