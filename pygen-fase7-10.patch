+    },
+    {
+      "id": "classification_report",
+      "title": "Classification Report — Precision, Recall, F1",
+      "description": "Hitung precision, recall, F1 per class + macro/weighted average. Stdlib only.",
+      "imports": [],
+      "requires": {},
+      "fields": [
+        {"name": "nama_fungsi", "label": "Nama fungsi", "type": "identifier", "default": "classification_report"}
+      ],
+      "code": "def {{nama_fungsi}}(y_true, y_pred, labels=None, digits=4):\n    \"\"\"Generate classification report with precision, recall, F1 per class.\n    Returns dict with per-class metrics and averages.\n    \"\"\"\n    if labels is None:\n        labels = sorted(set(y_true) | set(y_pred))\n    report = {}\n    total = len(y_true)\n    for label in labels:\n        tp = sum(1 for t, p in zip(y_true, y_pred) if t == label and p == label)\n        fp = sum(1 for t, p in zip(y_true, y_pred) if t != label and p == label)\n        fn = sum(1 for t, p in zip(y_true, y_pred) if t == label and p != label)\n        precision = tp / (tp + fp) if (tp + fp) > 0 else 0.0\n        recall = tp / (tp + fn) if (tp + fn) > 0 else 0.0\n        f1 = 2 * precision * recall / (precision + recall) if (precision + recall) > 0 else 0.0\n        support = sum(1 for t in y_true if t == label)\n        report[label] = {\n            'precision': round(precision, digits),\n            'recall': round(recall, digits),\n            'f1': round(f1, digits),\n            'support': support,\n        }\n    # Macro average\n    n_classes = len(labels)\n    report['_macro_avg'] = {\n        'precision': round(sum(r['precision'] for r in report.values() if isinstance(r, dict) and 'precision' in r) / n_classes, digits),\n        'recall': round(sum(r['recall'] for r in report.values() if isinstance(r, dict) and 'recall' in r) / n_classes, digits),\n        'f1': round(sum(r['f1'] for r in report.values() if isinstance(r, dict) and 'f1' in r) / n_classes, digits),\n        'support': total,\n    }\n    # Weighted average\n    if total > 0:\n        report['_weighted_avg'] = {\n            'precision': round(sum(r['precision'] * r['support'] for r in report.values() if isinstance(r, dict) and 'precision' in r) / total, digits),\n            'recall': round(sum(r['recall'] * r['support'] for r in report.values() if isinstance(r, dict) and 'recall' in r) / total, digits),\n            'f1': round(sum(r['f1'] * r['support'] for r in report.values() if isinstance(r, dict) and 'f1' in r) / total, digits),\n            'support': total,\n        }\n    report['_accuracy'] = sum(1 for t, p in zip(y_true, y_pred) if t == p) / total if total > 0 else 0.0\n    return report\n",
